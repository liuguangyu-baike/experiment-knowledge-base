{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "实验知识库 - 单条实验记录",
  "description": "基于初高中理化生地教材'实验·探究'栏目提取的结构化实验数据，服务于动画课、探究课设计和线上模拟实验",
  "type": "object",
  "required": ["id", "name", "subject", "grade", "publisher", "source", "purpose", "type"],
  "properties": {
    "id": {
      "type": "string",
      "description": "唯一标识符，格式：[学科缩写]-[年级缩写]-[序号]",
      "examples": ["bio-7a-01", "phy-8a-03", "chem-9a-02"]
    },
    "name": {
      "type": "string",
      "description": "实验名称（教材'实验·探究'栏目中的标题）"
    },
    "subject": {
      "type": "string",
      "enum": ["生物", "物理", "化学", "地理"],
      "description": "学科"
    },
    "grade": {
      "type": "string",
      "description": "年级册别",
      "examples": ["七年级上", "八年级下", "高中必修1", "高中选择性必修2"]
    },
    "publisher": {
      "type": "string",
      "description": "教材版本（出版方），用于多版本查询过滤",
      "examples": ["人教版", "北师大版", "沪教版"]
    },
    "source": {
      "type": "object",
      "description": "教材出处",
      "required": ["textbook", "pages"],
      "properties": {
        "textbook": {
          "type": "string",
          "description": "教材版本",
          "examples": ["人教版2024"]
        },
        "chapter": {
          "type": "string",
          "description": "章节号",
          "examples": ["1.2.1", "3.4"]
        },
        "pages": {
          "type": "array",
          "items": { "type": "integer" },
          "description": "涉及的页码"
        },
        "section_type": {
          "type": "string",
          "description": "所在栏目类型",
          "const": "实验·探究"
        }
      }
    },
    "purpose": {
      "type": "string",
      "description": "实验目的 / 学习目标"
    },
    "type": {
      "type": "string",
      "enum": ["观察/探索", "调参/验证", "技能训练", "工程/制作"],
      "description": "实验的认知类型"
    },
    "inquiry_method": {
      "type": "string",
      "description": "一句话概括学生需要做什么操作（20-30字）"
    },
    "equipment": {
      "type": "array",
      "items": { "type": "string" },
      "description": "可复用的实验器材（工具、装置），如显微镜、烧杯、天平"
    },
    "materials": {
      "type": "array",
      "items": { "type": "string" },
      "description": "仅在当前实验使用的样本/材料，如洋葱、池塘水"
    },
    "functional_components": {
      "type": "string",
      "description": "线上模拟中需要实现交互功能的组件及其功能（实验粒度，同一组件在不同实验中功能可不同）。仅记录有测量/调节/观察/控制等功能的仪器，不记录简单容器",
      "examples": [
        "显微镜(调焦、切换放大倍数、反光镜调节、光圈调节)",
        "弹簧测力计(测量拉力、读数)"
      ]
    },
    "steps": {
      "type": "array",
      "description": "实验步骤，支持多级层次",
      "items": {
        "type": "object",
        "required": ["step"],
        "properties": {
          "step": {
            "type": "string",
            "description": "主步骤"
          },
          "substeps": {
            "type": "array",
            "items": { "type": "string" },
            "description": "子步骤（可选）"
          }
        }
      }
    },
    "data_recording": {
      "type": "string",
      "description": "需要记录的数据/观察结果。无则填'无'"
    },
    "independent_var": {
      "type": "string",
      "description": "自变量：数量+具体内容（含取值/梯度）。无则填'无'",
      "examples": ["1个(光照强度: 有光 vs 无光)", "无"]
    },
    "dependent_var": {
      "type": "string",
      "description": "因变量：数量+类型(定性/定量)+具体内容。无则填'无'",
      "examples": ["1个 定性(鼠妇的分布位置)", "1个 定量(气泡产生的数量)", "无"]
    },
    "control_group": {
      "type": "string",
      "description": "对照组设置：有/无+描述+对照方式。无则填'无'",
      "examples": ["有 明亮环境 vs 黑暗环境(相互对照)", "无"]
    },
    "inquiry_skills": {
      "type": "array",
      "items": { "type": "string" },
      "description": "该实验中渗透的操作性知识/探究知识，即在探究课中可以作为知识点教给学生的内容（如控制变量法、淀粉遇碘变蓝、临时装片制作技术等）。不包含通用思维方法（分析、推理、归纳等）和通用探究过程（提出问题、观察等）"
    },
    "inquiry_openness": {
      "type": "object",
      "description": "5维度探究开放度评价，每个维度用Herron 4级",
      "properties": {
        "question": {
          "type": "string",
          "enum": ["Confirmation", "Structured", "Guided", "Open", "N/A"],
          "description": "提出问题：谁提出探究问题"
        },
        "hypothesis": {
          "type": "string",
          "enum": ["Confirmation", "Structured", "Guided", "Open", "N/A"],
          "description": "作出假设：谁提出假设"
        },
        "experiment_design": {
          "type": "string",
          "enum": ["Confirmation", "Structured", "Guided", "Open", "N/A"],
          "description": "设计实验：谁设计实验方案"
        },
        "data_analysis": {
          "type": "string",
          "enum": ["Confirmation", "Structured", "Guided", "Open", "N/A"],
          "description": "分析数据：谁分析数据/结果"
        },
        "conclusion": {
          "type": "string",
          "enum": ["Confirmation", "Structured", "Guided", "Open", "N/A"],
          "description": "得出结论：谁得出最终结论"
        }
      }
    },
    "cautions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "注意事项、安全提示"
    },
    "notes": {
      "type": "string",
      "description": "备注（特殊要求、模拟建议等）"
    }
  }
}
